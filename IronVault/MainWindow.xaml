<Window x:Class="IronVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IronVault"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="SelectFileButton" Content="Select File" HorizontalAlignment="Left" Margin="69,45,0,0" VerticalAlignment="Top" Height="41" Width="112" FontSize="20" Click="SelectFileButton_Click" RenderTransformOrigin="0.385,0.559" Background="#FF0BC95B"/>
        <Label Content="Password:" HorizontalAlignment="Left" Margin="69,110,0,0" VerticalAlignment="Top" Width="112" FontSize="20" Background="#FF1FC1E5" HorizontalContentAlignment="Center"/>
        <Button x:Name="GoButton" Content="Go!" HorizontalAlignment="Center" Height="86" Margin="0,217,0,0" VerticalAlignment="Top" Width="164" FontSize="48" Click="GoButton_Click" Background="#FF1BDFD1"/>
        <PasswordBox x:Name="PasswordBox" HorizontalAlignment="Left" Height="42" Margin="198,110,0,0" VerticalAlignment="Top" Width="192" FontSize="20" VerticalContentAlignment="Center"/>
        <TextBox x:Name="FilePathTextBox" HorizontalAlignment="Left" Height="41" Margin="198,45,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="580" TextChanged="TextBox_TextChanged" FontSize="16" IsReadOnly="True" VerticalContentAlignment="Center"/>

    </Grid>
</Window>
