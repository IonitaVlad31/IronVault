<Window x:Class="IronVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IronVault"
        mc:Ignorable="d"
        Title="IronVault Security" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="WhiteSmoke"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Background="DarkSlateGray" Padding="20">
            <TextBlock Text="IRON VAULT" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">
            <TextBlock Text="Select File" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="DimGray"/>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="FilePathTextBox" 
                         Height="40" 
                         FontSize="14" 
                         VerticalContentAlignment="Center" 
                         Padding="5"
                         IsReadOnly="True" 
                         Background="White"
                         BorderBrush="LightGray"
                         BorderThickness="1"
                         AllowDrop="True"
                         PreviewDragOver="FilePathTextBox_PreviewDragOver"
                         PreviewDragEnter="FilePathTextBox_PreviewDragEnter"
                         PreviewDragLeave="FilePathTextBox_PreviewDragLeave"
                         Drop="FilePathTextBox_Drop"/>

                <Button x:Name="SelectFileButton" 
                        Content="..." 
                        Grid.Column="1" 
                        Width="50" 
                        Height="40" 
                        Margin="10,0,0,0" 
                        Click="SelectFileButton_Click"
                        ToolTip="Browse for file"/>
            </Grid>

            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="DimGray"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="40" 
                         FontSize="16" 
                         Padding="5"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,30"
                         Background="White"
                         BorderBrush="LightGray"
                         BorderThickness="1"/>

            <Button x:Name="GoButton" 
                    Content="ENCRYPT / DECRYPT" 
                    Height="60" 
                    FontSize="18" 
                    FontWeight="Bold"
                    Click="GoButton_Click" 
                    Background="MediumTurquoise" 
                    Foreground="Black"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="20">
            <ProgressBar x:Name="EncryptionProgressBar" 
                         Height="10" 
                         Minimum="0" 
                         Maximum="100" 
                         Value="0" 
                         Background="Gainsboro" 
                         Foreground="DodgerBlue" 
                         BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
